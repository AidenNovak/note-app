    <!-- Comparison Table -->
    <section class="mt-16">
      <h2 class="font-display text-xl font-semibold text-atelier-forest mb-6">方案对比速览</h2>
      <div class="overflow-x-auto rounded-2xl border border-atelier-outlineVariant/30 bg-white">
        <table class="min-w-full text-sm">
          <thead class="bg-atelier-surface text-atelier-onSurfaceVariant uppercase text-xs tracking-wider">
            <tr>
              <th class="text-left px-5 py-3 font-semibold">方案</th>
              <th class="text-left px-5 py-3 font-semibold">色彩策略</th>
              <th class="text-left px-5 py-3 font-semibold">视觉强度</th>
              <th class="text-left px-5 py-3 font-semibold">RN 实现难度</th>
              <th class="text-left px-5 py-3 font-semibold">推荐场景</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-atelier-outlineVariant/20 text-atelier-onSurface">
            <tr>
              <td class="px-5 py-3.5 font-medium">01. Baseline</td>
              <td class="px-5 py-3.5">单一淡绿条</td>
              <td class="px-5 py-3.5">★☆☆☆☆</td>
              <td class="px-5 py-3.5">极易</td>
              <td class="px-5 py-3.5">极简主义优先</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium">02. Soft Pastel</td>
              <td class="px-5 py-3.5">卡片整体马卡龙色</td>
              <td class="px-5 py-3.5">★★★☆☆</td>
              <td class="px-5 py-3.5">容易</td>
              <td class="px-5 py-3.5">情感化、日记类产品</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium">03. Gradient Edge</td>
              <td class="px-5 py-3.5">品牌绿渐变条+微渐变背景</td>
              <td class="px-5 py-3.5">★★★★☆</td>
              <td class="px-5 py-3.5">中等</td>
              <td class="px-5 py-3.5">强化品牌识别</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium">04. Glassmorphism</td>
              <td class="px-5 py-3.5">半透明+背景透色</td>
              <td class="px-5 py-3.5">★★★★☆</td>
              <td class="px-5 py-3.5">较难</td>
              <td class="px-5 py-3.5">追求前沿视觉体验</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium">05. Color Header</td>
              <td class="px-5 py-3.5">顶部彩色分类横幅</td>
              <td class="px-5 py-3.5">★★★☆☆</td>
              <td class="px-5 py-3.5">容易</td>
              <td class="px-5 py-3.5">分类多、需快速识别</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium">06. Mood Status</td>
              <td class="px-5 py-3.5">状态图标+边框颜色</td>
              <td class="px-5 py-3.5">★★★☆☆</td>
              <td class="px-5 py-3.5">容易</td>
              <td class="px-5 py-3.5">任务流、处理状态重要</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium">07. Badge Tags</td>
              <td class="px-5 py-3.5">标签彩色徽章</td>
              <td class="px-5 py-3.5">★★☆☆☆</td>
              <td class="px-5 py-3.5">极易</td>
              <td class="px-5 py-3.5">最小改动、最大效果</td>
            </tr>
            <tr class="bg-atelier-primaryFixed/20">
              <td class="px-5 py-3.5 font-bold text-atelier-forest">08. Nature Organic</td>
              <td class="px-5 py-3.5 font-medium text-atelier-forest">奶油纸感+品牌绿/黄绿条</td>
              <td class="px-5 py-3.5 font-medium text-atelier-forest">★★★☆☆</td>
              <td class="px-5 py-3.5 font-medium text-atelier-forest">中等</td>
              <td class="px-5 py-3.5 font-medium text-atelier-forest">★ 最契合 atelier 品牌</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Recommendation -->
    <section class="mt-12 mb-20">
      <div class="rounded-3xl bg-gradient-to-br from-atelier-forest to-[#1a3d2a] p-8 md:p-10 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-atelier-lime/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
        <div class="relative z-10">
          <h2 class="font-display text-2xl font-bold mb-4">设计建议</h2>
          <div class="space-y-3 text-atelier-cream/90 leading-relaxed max-w-3xl">
            <p>
              如果希望 <strong>最小风险、最大提升</strong>，推荐从 <span class="text-atelier-lime font-semibold">07. Badge Tags</span> 入手：
              仅将标签从纯文本改为彩色小徽章，即可在不破坏现有信息层级的前提下显著增加活力。
            </p>
            <p>
              如果希望 <strong>深度契合 atelier "Second Digital Mind" 的品牌叙事</strong>，
              我们更推荐 <span class="text-atelier-lime font-semibold">08. Nature Organic</span>：
              它通过奶油色纸张质感、更大的圆角和森林绿/黄绿的色彩点缀，让 Inbox 像一本摊开的笔记本，
              每一次滑动都像在翻阅思绪的叶子。
            </p>
            <p>
              另外，<span class="text-atelier-lime font-semibold">03. Gradient Edge</span> 是品牌色运用的现代诠释，
              适合在保持专业感的同时注入更多视觉能量。
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>

</body>
</html>
