# Truth Truth (T²) backend environment variables
# Copy this file to .env and fill in the values.
# Note: the legacy "atelier" slug appears in some identifiers (bundle ID,
# R2 bucket name, IAP product IDs) — those are technical interfaces and
# must stay as-is. Brand-facing strings have been rebranded.

# ============================================
# Core application
# ============================================
APP_ENV=development
APP_NAME=Truth Truth API
APP_VERSION=1.0.0

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-with-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Database
# ============================================
# Local development defaults to SQLite.
DATABASE_URL=sqlite+aiosqlite:///./data/notes.db

# Production typically uses PostgreSQL.
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ============================================
# Local file storage / upload limits
# ============================================
STORAGE_PATH=./data/files
MAX_FILE_SIZE_MB=500

# Public backend origin used for generated file URLs and internal callbacks.
# The variable name is legacy, but it is still the current runtime setting.
EASYSTARTER_SERVER_URL=http://localhost:8000

# Legal / email link base URL
FRONTEND_URL=https://app.jilly.app

# Optional explicit override
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# ============================================
# Development/runtime behavior
# ============================================
DEV_AUTO_LOGIN=false
RATE_LIMIT_STORAGE_URI=memory://

# ============================================
# OAuth providers
# ============================================
APPLE_APP_BUNDLE_IDENTIFIER=app.jilly.atelier
APPLE_TEAM_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# Payments
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
REVENUECAT_WEBHOOK_AUTHORIZATION=

# ============================================
# Email
# ============================================
RESEND_API_KEY=
EMAIL_FROM_NAME=Truth Truth
EMAIL_FROM_ADDRESS=noreply@jilly.app

# ============================================
# Object storage (R2 via S3 API)
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=atelier-bucket
CDN_BASE_URL=https://cdn.jilly.app

# ============================================
# AI / embeddings / transcription
# ============================================
# Primary provider: "cloudflare" (default) | "openrouter" (fallback/rollback)
AI_PROVIDER=cloudflare

# Cloudflare Workers AI — obtain at https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=
CF_ACCOUNT_ID=

# Model defaults (Cloudflare Workers AI model IDs)
AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
INSIGHTS_AI_MODEL=@cf/deepseek-ai/deepseek-r1-distill-qwen-32b
EMBEDDING_MODEL=@cf/baai/bge-m3
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_STREAMING=true

# Used for Whisper transcription only
OPENAI_API_KEY=

# ── OpenRouter (rollback only — set AI_PROVIDER=openrouter to re-enable) ──
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=moonshotai/kimi-k2.5
# INSIGHTS_AI_MODEL=moonshotai/kimi-k2-thinking
# EMBEDDING_MODEL=openai/text-embedding-3-small

# ============================================
# Insight workspace
# ============================================
INSIGHTS_WORKSPACE_ROOT=./data/insights
INSIGHT_MAX_CONTEXT_NOTES=12
INSIGHT_MAX_NOTE_CHARS=4000
INSIGHT_AGENT_MAX_TURNS=30

# ============================================
# Workspace agent
# ============================================
AGENT_MAX_TURNS=25
AGENT_MAX_TOKENS_PER_TURN=4096
AGENT_REQUEST_TIMEOUT=180
AGENT_MAX_NOTES=50
