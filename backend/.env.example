# Atelier Backend Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Application Settings
# ============================================
APP_ENV=development  # development | test | production
APP_NAME=atelier API
APP_VERSION=1.0.0

# ============================================
# Security (REQUIRED)
# ============================================
# CRITICAL: Generate a secure random key with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-must-be-at-least-32-chars

# JWT Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Database
# ============================================
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/notes.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/atelier

# Vercel (auto-configured from POSTGRES_URL)
# POSTGRES_URL=postgresql://...
# POSTGRES_URL_NON_POOLING=postgresql://...

# ============================================
# Storage
# ============================================
STORAGE_PATH=./data/files
MAX_FILE_SIZE_MB=500

EASYSTARTER_SERVER_URL=http://localhost:3001
STORAGE_MIGRATION_TOKEN=

# ============================================
# CORS Origins
# ============================================
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ============================================
# AI Provider
# ============================================
# Default: claude-sdk (uses Anthropic Python SDK directly)
# Alternative: openrouter (requires API key)
AI_PROVIDER=claude-sdk

# Anthropic API Key (required if AI_PROVIDER=claude-sdk)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenRouter (only needed if AI_PROVIDER=openrouter)
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# OPENROUTER_MODEL=minimax/minimax-m2.7
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# ============================================
# Insights Configuration
# ============================================
INSIGHTS_WORKSPACE_ROOT=./data/insights
INSIGHT_MAX_CONTEXT_NOTES=12
INSIGHT_MAX_NOTE_CHARS=4000
INSIGHT_AGENT_MAX_TURNS=30

# ============================================
# Development Only
# ============================================
# For local development, you can use a simple SECRET_KEY
# SECRET_KEY=dev-secret-key-only-for-local-testing-min-32-chars
