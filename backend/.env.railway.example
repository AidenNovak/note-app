# Railway deployment environment variables
# Copy these into Railway -> Variables and fill in the secrets.

# ============================================
# Core
# ============================================
APP_ENV=production
APP_NAME=Truth Truth API
APP_VERSION=1.0.0
SECRET_KEY=
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
EASYSTARTER_SERVER_URL=https://backend.jilly.app
FRONTEND_URL=https://app.jilly.app
RATE_LIMIT_STORAGE_URI=memory://

# ============================================
# OAuth
# ============================================
APPLE_APP_BUNDLE_IDENTIFIER=app.jilly.atelier
APPLE_TEAM_ID=7533A52C52
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# Payments
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
REVENUECAT_WEBHOOK_AUTHORIZATION=

# ============================================
# Email
# ============================================
RESEND_API_KEY=
EMAIL_FROM_NAME=Truth Truth
EMAIL_FROM_ADDRESS=noreply@jilly.app

# ============================================
# Storage (R2)
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=atelier-bucket
CDN_BASE_URL=https://cdn.jilly.app

# ============================================
# AI / embeddings / transcription
# ============================================
AI_PROVIDER=cloudflare
CF_API_TOKEN=
CF_ACCOUNT_ID=
AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
INSIGHTS_AI_MODEL=@cf/deepseek-ai/deepseek-r1-distill-qwen-32b
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_STREAMING=true
OPENAI_API_KEY=
EMBEDDING_MODEL=@cf/baai/bge-m3
# Rollback: set AI_PROVIDER=openrouter and uncomment below
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# Insight workspace
# ============================================
INSIGHTS_WORKSPACE_ROOT=./data/insights
INSIGHT_MAX_CONTEXT_NOTES=12
INSIGHT_MAX_NOTE_CHARS=4000
INSIGHT_AGENT_MAX_TURNS=30

# ============================================
# Workspace agent
# ============================================
AGENT_MAX_TURNS=25
AGENT_MAX_TOKENS_PER_TURN=4096
AGENT_REQUEST_TIMEOUT=180
AGENT_MAX_NOTES=50
